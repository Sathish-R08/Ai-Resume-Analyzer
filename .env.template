# You need at least ONE of these API keys for the AI analysis to work without Puter.js
# Create a copy of this file and name it '.env', then fill in your preferred key.

# Option 1: Google Gemini (Recommended, fastest and free tier available)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Option 2: Anthropic Claude (The original model used by Puter)
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here
